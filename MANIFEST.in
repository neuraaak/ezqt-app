# Main documentation
include README.md
include CHANGELOG.md
include LICENSE
include MANIFEST.in

# Documentation
recursive-include docs *.md

# EzQt_App package resources
recursive-include src/ezqt_app/resources *
recursive-include src/ezqt_app/widgets *
recursive-include src/ezqt_app/cli *
recursive-include examples *

# Configuration files
include src/ezqt_app/py.typed

# Test files
include tests/run_tests.py
include tests/pytest.ini
include tests/conftest.py
recursive-include tests/unit *

# Exclude unnecessary files
exclude build_upload.bat
exclude .coverage
exclude coverage.xml
exclude htmlcov/
exclude .pytest_cache/
exclude .benchmarks/
exclude _temp/
exclude *.tmp
exclude *.temp
prune build
prune dist
prune EzQt_App.egg-info
prune __pycache__
prune .venv
prune .vscode
prune .idea
prune .git
